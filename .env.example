# ProxySITE - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# ============== SEGURANÇA DO PROXY ==============
# Gere uma chave secreta forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_SECRET_KEY_HERE_CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============== BANCO DE DADOS ==============
DATABASE_URL=postgresql://postgres:password@localhost:5432/proxy_db

# ============== REDIS ==============
REDIS_URL=redis://localhost:6380/0

# ============== APIs EXTERNAS ==============
UAZAPI_TOKEN=YOUR_UAZAPI_TOKEN_HERE
BASILEIA_API_KEY=YOUR_BASILEIA_API_KEY_HERE

# ============== SECURITY ==============
# Lista de IPs permitida para webhooks (separados por vírgula)
ALLOWED_WEBHOOK_IPS=127.0.0.1,::1
# Rate limiting: requisições por minuto
RATE_LIMIT_PER_MINUTE=60
# Ambiente
ENVIRONMENT=development
# Chave para webhooks
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# ============== SUBSISTEMA SECURE EVENTS ==============
# JWT próprio do subsistema (diferente do JWT do proxy)
EVENTS_JWT_SECRET=YOUR_EVENTS_SECRET_KEY_HERE
EVENTS_ACCESS_TOKEN_EXPIRE_MINUTES=60
EVENTS_REFRESH_TOKEN_EXPIRE_DAYS=7

# Comunicação com BasileaEvents
EVENTS_INTERNAL_API_SECRET=YOUR_INTERNAL_API_SECRET
EVENTS_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
EVENTS_WEBHOOK_URL=https://events.basileia.app/webhooks/facial-checkin

# Engine facial (aws_rekognition ou compreface)
FACE_ENGINE=aws_rekognition
AWS_REKOGNITION_REGION=us-east-1
FACE_S3_BUCKET=basileia-secure-faces
FACE_S3_PREFIX=events/faces

# Configurações do reconhecimento
FACE_SIMILARITY_THRESHOLD=0.85
FACE_MIN_QUALITY_SCORE=0.70
FACE_RETENTION_DAYS=90
FACE_AUTO_DELETE=true

# Rate limiting
EVENTS_RATE_LIMIT_RECOGNIZE=10
EVENTS_RATE_LIMIT_CHECKIN=5
EVENTS_RATE_LIMIT_AUTH=5

# Brute-force protection
EVENTS_MAX_FAILED_ATTEMPTS=5
EVENTS_LOCKOUT_MINUTES=15

# Totem
TOTEM_API_KEY_SALT=YOUR_SALT_HERE

# Primeiro admin (seed inicial — trocar após primeiro login)
EVENTS_ADMIN_EMAIL=admin@basileia.app
EVENTS_ADMIN_PASSWORD=CHANGE_ME_AFTER_FIRST_LOGIN

# ============== CRYPTO KEYS ==============
# ATENÇÃO: Gerar APENAS uma vez e nunca mais modificar em produção!
# Gere com: python -c "from cryptography.fernet import Fernet; import secrets; print('SECURE_MASTER_KEY=' + Fernet.generate_key().decode()); print('SECURE_WEBHOOK_SECRET=' + secrets.token_hex(16)); print('QR_HMAC_SECRET=' + secrets.token_hex(32))"
SECURE_MASTER_KEY=GENERATE_WITH_PYTHON_SCRIPT
SECURE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
QR_HMAC_SECRET=YOUR_QR_HMAC_SECRET_HERE